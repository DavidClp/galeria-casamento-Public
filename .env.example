PORT=4000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/galeria_casamento?schema=public

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=casamento-gallery

# Public base URL for objects (custom domain or https://pub-xxx.r2.dev)
# No trailing slash
R2_PUBLIC_URL=https://your-public-r2-domain.com

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:3000

# Public API URL (used for local-file fallback links)
PUBLIC_API_URL=http://localhost:4000

# Local dual-storage directory
LOCAL_MEDIA_DIR=./data/media
